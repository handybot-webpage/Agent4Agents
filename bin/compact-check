#!/usr/bin/env python3
"""compact-check — enforce Project Compact governance rules.

Usage:
  compact-check <base-ref> <head-ref>

Checks (v1):
  1. Frozen prefix files (agent-context/0*-*.md, 1*-*.md, 2*-*.md) may
     only change in PRs that include a Tier 2 charter.
  2. Accepted ADR files in docs/adr/ have immutable bodies. Only the
     'Superseded by:' field may change on existing ADRs. To change a
     decision, write a new superseding ADR.
  3. Append-only logs (silent-decisions-log.md, pending-decisions.md,
     10-adr-index.md, 20-module-index.md) may only gain lines, never
     lose them.

Exit codes:
  0 - all checks pass
  1 - one or more violations
  2 - script error (bad args, git failure)

See ARCHITECTURE.md §9 (Governance layer) for the rationale.
"""

import re
import subprocess
import sys
from typing import List, Tuple

FROZEN_PATTERNS = [
    re.compile(r"^agent-context/0\d-.+\.md$"),
    re.compile(r"^agent-context/1\d-.+\.md$"),
    re.compile(r"^agent-context/2\d-.+\.md$"),
]
APPEND_ONLY_LOGS = {
    "tasks/silent-decisions-log.md",
    "tasks/pending-decisions.md",
    "agent-context/10-adr-index.md",
    "agent-context/20-module-index.md",
}
ADR_PATTERN = re.compile(r"^docs/adr/\d{4}-\d{2}-\d{2}-\d+-.+\.md$")
ADR_TEMPLATE = "docs/adr/template.md"
CHARTER_PATTERN = re.compile(r"^tasks/.+\.charter\.md$")
TIER2_LINE = re.compile(r"^\s*\*\*Tier:\*\*\s*2\b", re.MULTILINE)
SUPERSEDED_BY_LINE = re.compile(r"^\s*-?\s*\*\*Superseded by:\*\*")


def sh(cmd: List[str]) -> str:
    """Run a command, return stdout. Raises CalledProcessError on non-zero exit."""
    return subprocess.run(
        cmd, capture_output=True, text=True, check=True
    ).stdout


def diff_files(base: str, head: str) -> List[Tuple[str, str]]:
    """Return [(status, path), ...] for files changed in base..head."""
    out = sh(["git", "diff", "--name-status", f"{base}..{head}"])
    result = []
    for line in out.strip().splitlines():
        if "\t" not in line:
            continue
        parts = line.split("\t")
        # Handle rename (R100 old new) — treat as modify of new path
        if parts[0].startswith("R") and len(parts) == 3:
            result.append(("M", parts[2]))
        else:
            result.append((parts[0], parts[1]))
    return result


def added_removed(path: str, base: str, head: str) -> Tuple[List[str], List[str]]:
    """Return (added_lines, removed_lines) for one file in the diff."""
    try:
        out = sh(["git", "diff", "--no-color", f"{base}..{head}", "--", path])
    except subprocess.CalledProcessError:
        return [], []
    added, removed = [], []
    for ln in out.splitlines():
        if ln.startswith(("+++", "---", "@@", "diff ", "index ", "new file mode", "deleted file mode")):
            continue
        if ln.startswith("+"):
            added.append(ln[1:])
        elif ln.startswith("-"):
            removed.append(ln[1:])
    return added, removed


def is_frozen(path: str) -> bool:
    return any(rx.match(path) for rx in FROZEN_PATTERNS)


def is_adr(path: str) -> bool:
    return bool(ADR_PATTERN.match(path)) and path != ADR_TEMPLATE


def pr_has_tier2_charter(diff: List[Tuple[str, str]], head: str) -> bool:
    """True if a charter file added in this PR declares Tier 2."""
    for status, path in diff:
        if status == "A" and CHARTER_PATTERN.match(path):
            try:
                text = sh(["git", "show", f"{head}:{path}"])
                if TIER2_LINE.search(text):
                    return True
            except subprocess.CalledProcessError:
                pass
    return False


def check_frozen(diff, has_tier2) -> List[str]:
    """Frozen prefix files require a Tier 2 charter in the same PR."""
    bad = []
    for status, path in diff:
        if is_frozen(path) and not has_tier2:
            bad.append(
                f"  ✗ {path}: frozen prefix file changed without a Tier 2 charter in this PR"
            )
    return bad


def check_adr_immutable(diff, base, head) -> List[str]:
    """Accepted ADR bodies are immutable except for 'Superseded by:' line."""
    bad = []
    for status, path in diff:
        if status != "M" or not is_adr(path):
            continue
        added, removed = added_removed(path, base, head)
        suspect = [
            ln for ln in (added + removed)
            if ln.strip() and not SUPERSEDED_BY_LINE.match(ln)
        ]
        if suspect:
            bad.append(
                f"  ✗ {path}: accepted ADR body modified ({len(suspect)} line(s) "
                f"changed outside 'Superseded by:'); write a new superseding ADR instead"
            )
    return bad


def check_append_only(diff, base, head) -> List[str]:
    """Append-only logs only gain lines, never lose them."""
    bad = []
    for status, path in diff:
        if path not in APPEND_ONLY_LOGS:
            continue
        if status == "D":
            bad.append(f"  ✗ {path}: append-only log deleted")
            continue
        if status != "M":
            continue
        _, removed = added_removed(path, base, head)
        if removed:
            bad.append(
                f"  ✗ {path}: append-only log has {len(removed)} line(s) removed"
            )
    return bad


def main(argv: List[str]) -> int:
    if len(argv) != 3:
        print(f"usage: {argv[0]} <base-ref> <head-ref>", file=sys.stderr)
        return 2

    base, head = argv[1], argv[2]

    try:
        diff = diff_files(base, head)
    except subprocess.CalledProcessError as e:
        print(f"compact-check: git diff failed: {e.stderr.strip()}", file=sys.stderr)
        return 2

    has_t2 = pr_has_tier2_charter(diff, head)

    violations: List[str] = []
    violations += check_frozen(diff, has_t2)
    violations += check_adr_immutable(diff, base, head)
    violations += check_append_only(diff, base, head)

    if not violations:
        print(f"compact-check: ok ({len(diff)} file(s) reviewed)")
        return 0

    print(f"compact-check: {len(violations)} violation(s)", file=sys.stderr)
    for v in violations:
        print(v, file=sys.stderr)
    print("", file=sys.stderr)
    print("see ARCHITECTURE.md §9 (Governance layer) for the rules.", file=sys.stderr)
    return 1


if __name__ == "__main__":
    sys.exit(main(sys.argv))
